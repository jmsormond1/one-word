# From Firebase Console → Project settings → Your apps (Web). Also copy the Realtime
# Database URL from Realtime Database (not always the same as the default below).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
