{
  "rules": {
    "story": {
      ".read": true,
      ".write": false
    },
    "archive": {
      ".read": true,
      "$date": {
        ".write": false
      }
    },
    "meta": {
      ".read": true,
      ".write": false
    },
    "round": {
      ".read": true,
      ".write": false
    },
    "proposals": {
      ".read": true,
      ".write": false,
      "$id": {
        ".read": true,
        ".write": "newData.exists() && newData.hasChild('text') && newData.hasChild('votes') && newData.child('text').isString() && newData.child('votes').isNumber()",
        ".validate": "(!data.exists() && newData.child('votes').val() == 0 && newData.child('text').val().matches(/^.{1,100}$/)) || (data.exists() && newData.child('text').val() == data.child('text').val() && newData.child('votes').val() == data.child('votes').val() + 1)"
      }
    }
  }
}
